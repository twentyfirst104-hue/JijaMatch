# ========================================================================
# Пример файла окружения. Скопируйте его в .env и подставьте свои значения:
#   Windows:        copy .env.example .env
#   macOS / Linux:  cp .env.example .env
# ========================================================================

# --- Telegram ---
# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# Ваш Telegram ID (число). Узнать можно у @userinfobot. Только этот человек = админ.
ADMIN_ID=123456789

# Ваш Telegram-username БЕЗ @ (для кнопки «Связаться с админом»)
ADMIN_USERNAME=your_username

# --- OpenRouter (ИИ) ---
# Ключ с https://openrouter.ai/keys (обязательно для ИИ-функций)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Основная модель и список фолбэков (через запятую). Бесплатные модели нестабильны,
# поэтому fallback-цепочка обязательна.
OPENROUTER_MODEL=deepseek/deepseek-chat:free
OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-7b-instruct:free

# Необязательные заголовки OpenRouter (можно оставить как есть)
OPENROUTER_HTTP_REFERER=https://t.me/your_bot
OPENROUTER_APP_TITLE=VapeFlavorCatalog

# --- Коэффициенты алгоритма (можно не трогать) ---
LIKE_WEIGHT_COEFFICIENT=1.0
FAVORITE_WEIGHT_COEFFICIENT=1.5
PAID_PRIORITY_COEFFICIENT=1.3
DISLIKE_RESET_THRESHOLD=15.0
FREE_PRODUCER_FLAVOR_LIMIT=20
PROFILE_REWEIGHT_EVERY_N_SWIPES=30

# --- Прочее ---
# Путь к файлу БД (по умолчанию data/bot.db)
DB_PATH=data/bot.db
